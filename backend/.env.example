APP_ENV=dev
CORS_ORIGINS=["http://localhost:5173"]

# Update to match your MySQL local setup
DATABASE_URL="mysql+pymysql://root:root@localhost:3306/flood_risk"

# Change this!
JWT_SECRET_KEY="change-me"

# ML model file (generated by scripts/train_model.py)
MODEL_PATH="app/ml/model.joblib"

# Alert simulation
ALERT_RISK_THRESHOLD=0.80
ALERT_SIMULATION_MODE=true
ALERT_COOLDOWN_SECONDS=300

# Twilio (optional). If enabled, set ALERT_SIMULATION_MODE=false.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

